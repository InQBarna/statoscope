{"kind":"overview","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/statoscopetutorial"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial"},"sections":[{"action":{"overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen","isActive":true},"title":"Statoscope basics","content":[{"inlineContent":[{"type":"text","text":"Statoscope is a small library to build apps with state management,"},{"type":"text","text":" "},{"text":"testing, effects management and dependency injection.","type":"text"}],"type":"paragraph"}],"kind":"hero"},{"image":null,"kind":"volume","chapters":[{"tutorials":["doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen","doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects","doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware","doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection","doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes"],"name":"Tutorials","content":[{"inlineContent":[{"text":"Jump into how state scopes are created, how to define When events,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"write acceptance test, trigger side effects or inject params to subscopes."}],"type":"paragraph"}]}],"content":[],"name":null}],"hierarchy":{"reference":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial","paths":[]},"metadata":{"estimatedTime":"2hr 20min","categoryPathComponent":"StatoscopeTutorial","role":"overview","title":"Statoscope basics","category":"Statoscope Architecture"},"references":{"doc://Statoscope/tutorials/Statoscope/01-01-StateAndWhen":{"title":"Create a simple Scope","estimatedTime":"20min","abstract":[{"type":"text","text":"Define a scope object with state member variables representing"},{"text":" ","type":"text"},{"text":"a part of your app’s status, define the events that may affect","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this state, and create a view to display the state."}],"kind":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen","type":"topic","url":"\/tutorials\/statoscope\/01-01-stateandwhen","role":"project"},"doc://Statoscope/tutorials/Statoscope/01-03-Middleware":{"role":"project","abstract":[{"text":"Understand how the single entry point enables pretty interesting features","type":"text"}],"kind":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware","type":"topic","estimatedTime":"30min","url":"\/tutorials\/statoscope\/01-03-middleware","title":"Single entry point and\/or middlewares"},"doc://Statoscope/tutorials/Statoscope/01-05-Scopes":{"role":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes","estimatedTime":"30min","url":"\/tutorials\/statoscope\/01-05-scopes","type":"topic","title":"Scopes","abstract":[{"text":"Defining all state and When events in a single Statostore doesn’t scale. We need to decide where exactly to split our state and events into separate state parts or Scopes. Sometimes separation is obvious and sometimes developers want to separate state and events that are inevitably coupled due to the nature of the business logic. However, this article will focus in how to separate the state of our apps in different scopes.","type":"text"}],"kind":"project"},"doc://Statoscope/tutorials/StatoscopeTutorial":{"role":"overview","identifier":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial","url":"\/tutorials\/statoscopetutorial","type":"topic","title":"Statoscope basics","abstract":[{"text":"Statoscope is a small library to build apps with state management,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"testing, effects management and dependency injection."}],"kind":"overview"},"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects":{"role":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects","estimatedTime":"30min","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects","type":"topic","title":"State, When and Effects","abstract":[{"type":"text","text":"Trigger effects that will get back to your scope as a new When event."}],"kind":"project"},"doc://Statoscope/tutorials/Statoscope/01-04-Injection":{"title":"Dependency Injection","estimatedTime":"30min","abstract":[{"type":"text","text":"Learn how to easily design dependencies and inject them into your scopes. Dependency injection simplifies the structure of your code by externalizing the management of dependencies, making your code more modular, testable, and flexible. In this tutorial, we will demonstrate dependency injection using an example of a simple news feed application."}],"kind":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection","type":"topic","url":"\/tutorials\/statoscope\/01-04-injection","role":"project"}}}