tatoscope\/01-03-Middleware"},"metadata":{"role":"project","categoryPathComponent":"StatoscopeTutorial","title":"Single entry point and\/or middlewares","category":"Statoscope Architecture"},"sections":[{"estimatedTimeInMinutes":30,"content":[{"inlineContent":[{"type":"text","text":"Understand how the single entry point enables pretty interesting features"}],"type":"paragraph"}],"chapter":"Tutorials","title":"Single entry point and\/or middlewares","kind":"hero"},{"kind":"tasks","tasks":[{"stepsSection":[{"caption":[],"runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s grab our first counter example adding some error throwing to illustrate the current example."}]}],"media":null,"code":"01-03-01-code-0001.swift"},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"And the CounterView with no protection to avoid the throw."}]}],"code":"01-03-01-code-0002.swift","runtimePreview":null,"type":"step","caption":[]},{"media":null,"code":"01-03-01-code-0003.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A middleware can be added to trap all events in the scope. Logging is straightforward,"},{"text":" ","type":"text"},{"type":"text","text":"either for terminal logging, analytics, or crash reports."}]}],"runtimePreview":null,"caption":[],"type":"step"},{"type":"paragraph","inlineContent":[{"text":"Having a comprehensive crash and analytics reporting is mandatory in production apps.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A single entry point\/middleware enables easy implementation for these features."}]}],"title":"Logging middleware","anchor":"Logging-middleware","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"Logging is an important part of the code. Debugging is great, but sometimes the scheduler","type":"text"},{"text":" ","type":"text"},{"type":"