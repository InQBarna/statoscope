ate parts or Scopes. Sometimes separation is obvious and sometimes developers want to separate state and events that are inevitably coupled due to the nature of the business logic. However, this article will focus in how to separate the state of our apps in different scopes.","type":"text"}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes#Views-and-scopes","type":"section","url":"\/tutorials\/statoscope\/01-05-scopes#Views-and-scopes","title":"Views and scopes"},"01-05-02-code-0005.swift":{"content":["struct ListView: View {","    @ObservedObject var model: NewsFeedList","    var body: some View {","        NavigationStack {","            ZStack {","                List(model.loadedDTO?.news ?? [], id: \\.id) { item in","                    Text(item.title)","                        .frame(maxWidth: .infinity)","                        .onTapGesture { _ in","                            model.send(.navigateToChild(id: item.id))","                        }","                }","                if model.loading {","                    ProgressView()","                }","            }","        }","        .navigationTitle(\"News\")","        .navigationDestination(","            isPresented: model.bindIsPresented(\\.readingArticle?.id, NewsFeedList.When.navigateToChild)","        ) {","            if let readingArticle = model.readingArticle {","                ArticleView(model: readingArticle)","            }","        }","    }","}"],"fileType":"swift","identifier":"01-05-02-code-0005.swift","fileName":"NewsFeedListView.swift","syntax":"swift","type":"file","highlights":[{"line":20}]},"01-05-02-code-0004.swift":{"fileName":"NewsFeedListView.swift","content":["struct ListView: View {","    @ObservedObject var model: NewsFeedList","    var body: some View {","        NavigationStack {","            ZStack {","                List(model.loadedDTO?.news ?? [], id: \\.id) { item in","                    Text(item.title)","         