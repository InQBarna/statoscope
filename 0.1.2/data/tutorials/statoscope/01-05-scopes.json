o separate state and events that are inevitably coupled due to the nature of the business logic. However, this article will focus in how to separate the state of our apps in different scopes.","type":"text"}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes#Design-scopes","type":"section","url":"\/tutorials\/statoscope\/01-05-scopes#Design-scopes","title":"Design scopes"},"01-05-02-code-0003.swift":{"highlights":[],"fileName":"NewsFeedListView.swift","syntax":"swift","fileType":"swift","content":["struct ListView: View {","    @ObservedObject var model: NewsFeedList","    var body: some View {","        NavigationStack {","            ZStack {","                List(model.loadedDTO?.news ?? [], id: \\.id) { item in","                    Text(item.title)","                        .frame(maxWidth: .infinity)","                        .onTapGesture { _ in","                            model.send(.navigateToChild(id: item.id))","                        }","                }","                if model.loading {","                    ProgressView()","                }","            }","        }","        .navigationTitle(\"News\")","    }","}"],"type":"file","identifier":"01-05-02-code-0003.swift"},"doc://Statoscope/tutorials/Statoscope/01-03-Middleware#Logging-middleware":{"title":"Logging middleware","abstract":[{"type":"text","text":"Understand how the single entry point enables pretty interesting features"}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware#Logging-middleware","type":"section","url":"\/tutorials\/statoscope\/01-03-middleware#Logging-middleware","role":"pseudoSymbol"},"01-05-01-code-0006.swift":{"highlights":[{"line":17},{"line":28}],"fileName":"NewsFeed.swift","syntax":"swift","fileType":"swift","content":["final class NewsFeed: Statostore, ObservableObject {","","    @Published var loadingFeatureToggles: Bool = true","    @Subscope var atList: NewsFeedList?","    ","    e