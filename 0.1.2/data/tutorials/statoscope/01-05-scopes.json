: NetworkProvider","    func update(_ when: When) throws { }","}"],"type":"file","identifier":"01-05-01-code-0009.swift"},"doc://Statoscope/tutorials/Statoscope/01-05-Scopes":{"role":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes","estimatedTime":"30min","url":"\/tutorials\/statoscope\/01-05-scopes","type":"topic","title":"Scopes","abstract":[{"text":"Defining all state and When events in a single Statostore doesn’t scale. We need to decide where exactly to split our state and events into separate state parts or Scopes. Sometimes separation is obvious and sometimes developers want to separate state and events that are inevitably coupled due to the nature of the business logic. However, this article will focus in how to separate the state of our apps in different scopes.","type":"text"}],"kind":"project"},"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects":{"role":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects","estimatedTime":"30min","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects","type":"topic","title":"State, When and Effects","abstract":[{"type":"text","text":"Trigger effects that will get back to your scope as a new When event."}],"kind":"project"},"doc://Statoscope/tutorials/StatoscopeTutorial/Tutorials":{"title":"Tutorials","abstract":[],"kind":"article","identifier":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial\/Tutorials","type":"topic","url":"\/tutorials\/statoscopetutorial\/tutorials","role":"article"},"doc://Statoscope/tutorials/StatoscopeTutorial":{"role":"overview","identifier":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial","url":"\/tutorials\/statoscopetutorial","type":"topic","title":"Statoscope basics","abstract":[{"text":"Statoscope is a small library to build apps with state management,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"testing, effects management and dependency injection."}],"kind":"overview"},"doc://Statoscope/tutorials/Statoscope/01-01-StateAndWhen#Create-your-view":{"title":"Create your view","abstract":[{"type":"text","text":"Define a scope object with state member variables representing"},{"type":"text","text":" "},{"text":"a part of your app’s status, define the events that may affect","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this state, and create a view to display the state."}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Create-your-view","type":"section","url":"\/tutorials\/statoscope\/01-01-stateandwhen#Create-your-view","role":"pseudoSymbol"},"doc://Statoscope/tutorials/Statoscope/01-04-Injection#Designing-a-Dependency":{"title":"Designing a Dependency","abstract":[{"type":"text","text":"Learn how to easily design dependencies and inject them into your scopes. Dependency injection simplifies the structure of your code by externalizing the management of dependencies, making your code more modular, testable, and flexible. In this tutorial, we will demonstrate dependency injection using an example of a simple news feed application."}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection#Designing-a-Dependency","type":"section","url":"\/tutorials\/statoscope\/01-04-injection#Designing-a-Dependency","role":"pseudoSymbol"},"01-05-02-code-0006.swift":{"highlights":[{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":34},{"line":35},{"line":36},{"line":37},{"line":38},{"line":39},{"line":40}],"fileName":"NewsFeedListView.swift","syntax":"swift","fileType":"swift","content":["struct ListView: View {","    @ObservedObject var model: NewsFeedList","    var body: some View {","        NavigationStack {","            ZStack {","                List(model.loadedDTO?.news ?? [], id: \\.id) { item in","                    Text(item.title)","                        .frame(maxWidth: .infinity)","                        .onTapGesture { _ in","                            model.send(.navigateToChild(id: item.id))","                        }","                }","                if model.loading {","                    ProgressView()","                }","            }","        }","        .navigationTitle(\"News\")","        .navigationDestination(","            isPresented: model.bindIsPresented(\\.readingArticle?.id, NewsFeedList.When.navigateToChild)","        ) {","            if let readingArticle = model.readingArticle {","                ArticleView(model: readingArticle)","            }","        }","    }","}","","struct ArticleView: View {","    @ObservedObject var model: NewsFeedArticle","    var body: some View {","        ZStack {","            Text(model.loadedDTO?.contentMarkdown ?? \"\")","            if model.loading {","                ProgressView()","            }","        }","        .navigationTitle(model.loadedDTO?.title ?? \"\")","    }","}"],"type":"file","identifier":"01-05-02-code-0006.swift"},"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects#What-is-a-side-effect":{"title":"What is a side effect?","abstract":[{"type":"text","text":"Trigger effects that will get back to your scope as a new When event."}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects#What-is-a-side-effect","type":"section","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects#What-is-a-side-effect","role":"pseudoSymbol"},"doc://Statoscope/tutorials/Statoscope/01-04-Injection":{"title":"Dependency Injection","estimatedTime":"30min","abstract":[{"type":"text","text":"Learn how to easily design dependencies and inject them into your scopes. Dependency injection simplifies the structure of your code by externalizing the management of dependencies, making your code more modular, testable, and flexible. In this tutorial, we will demonstrate dependency injection using an example of a simple news feed application."}],"kind":"project","identif