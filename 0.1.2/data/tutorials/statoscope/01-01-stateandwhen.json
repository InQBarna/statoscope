t with state member variables representing"},{"type":"text","text":" "},{"text":"a part of your app’s status, define the events that may affect","type":"text"},{"text":" ","type":"text"},{"text":"this state, and create a view to display the state.","type":"text"}],"url":"\/tutorials\/statoscope\/01-01-stateandwhen#Write-tests-and-acceptance-criterias","role":"pseudoSymbol","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Write-tests-and-acceptance-criterias","title":"Write tests and acceptance criterias","type":"section"},"StateAndWhen-CounterTests-01.swift":{"type":"file","content":["import StatoscopeTesting","","final class CounterTest: XCTestCase {","","    func testUserFlow() throws {","    }","","}"],"fileName":"CounterTests.swift","identifier":"StateAndWhen-CounterTests-01.swift","syntax":"swift","fileType":"swift","highlights":[]},"StateAndWhen-Counter-06.swift":{"type":"file","content":["import Statoscope","","private final class Counter: Scope, ObservableObject {","","    @Published var viewDisplaysTotalCount: Int = 0","","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","    }","","    func update(_ when: When) throws {","        switch when {","        case .userTappedIncrementButton:","            viewDisplaysTotalCount += 1","        case .userTappedDecrementButton:","            viewDisplaysTotalCount = max(0, viewDisplaysTotalCount - 1)","        }","    }","}"],"fileName":"Counter.swift","syntax":"swift","identifier":"StateAndWhen-Counter-06.swift","fileType":"swift","highlights":[{"line":3},{"line":5}]},"StateAndWhen-CounterTests-03.swift":{"type":"file","content":["import StatoscopeTesting","","final class CounterTest: XCTestCase {","","    func testUserFlow() throws {","        try Counter.GIVEN {","            Counter()","        }","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .WHEN(.userTappedIncrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 1)","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","    }","","}"],"fileName":"CounterTests.swift","identifier":"StateAndWhen-CounterTests-03.swift","syntax":"swift","fileType":"swift","highlights":[{"line":9},{"line":10},{"line":11},{"line":12},{"line":13},{"line":14},{"line":15}]},"doc://Statoscope/tutorials/Statoscope/01-04-Injection":{"type":"topic","url":"\/tutorials\/statoscope\/01-04-injection","abstract":[{"type":"text","text":"Learn how to easily design dependencies and inject them into your scopes. Dependency injection simplifies the structure of your code by externalizing the management of dependencies, making your code more modular, testable, and flexible. In this tutorial, we will demonstrate dependency injection using an example of a simple news feed application."}],"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection","role":"project","estimatedTime":"30min","title":"Dependency Injection","kind":"project"},"StateAndWhen-CounterView-01.png":{"identifier":"StateAndWhen-CounterView-01.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/StateAndWhen-CounterView-01.png"}],"type":"image"},"doc://Statoscope/tutorials/Statoscope/01-04-Injection#Designing-a-Dependency":{"type":"section","url":"\/tutorials\/statoscope\/01-04-injection#Designing-a-Dependency","abstract":[{"type":"text","text":"Learn how to easily design dependencies and inject them into your scopes. Dependency injection simplifies the structure of your code by externalizing the management of dependencies, making your code more modular, testable, and flexible. In this tutorial, we will demonstrate dependency injection using an example of a simple news feed application."}],"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection#Designing-a-Dependency","role":"pseudoSymbol","title":"Designing a Dependency","kind":"section"},"StateAndWhen-CounterView-01.swift":{"type":"file","content":["import SwiftUI","","struct CounterView: View {","    var body: some View {","        VStack {","            Text(\"0\")","            HStack {","                Button(\"+\") {","                }","                Button(\"-\") {","                }","            }","        }","    }","}"],"fileName":"CounterView","identifier":"StateAndWhen-CounterView-01.swift","syntax":"","fileType":"","highlights":[]},"doc://Statoscope/tutorials/Statoscope/01-05-Scopes":{"url":"\/tutorials\/statoscope\/01-05-scopes","abstract":[{"type":"text","text":"In complex applications, managing all state and events in a single Statostore quickly becomes unsustainable. To scale effectively, we need to split the app’s state and events into separate parts or Scopes. This process can sometimes be straightforward, but other times, developers may feel compelled to separate state and events that are closely tied together due to business logic. In this tutorial, we’ll focus on how to organize app state into different scopes to maintain scalability."}],"estimatedTime":"30min","title":"Scopes","type":"topic","role":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes","kind":"project"},"doc://Statoscope/tutorials/Statoscope/01-05-Scopes#Views-and-Scopes":{"kind":"section","abstract":[{"type":"text","text":"In complex applications, managing all state and events in a single Statostore quickly becomes unsustainable. To scale effectively, we need to split the app’s state and events into separate parts or Scopes. This process can sometimes be straightforward, but other times, developers may feel compelled to separate state and events that are closely tied together due to business logic. In this tutorial, we’ll focus on how to organize app state into different scopes to maintain scalability."}],"url":"\/tutorials\/statoscope\/01-05-scopes#Views-and-Scopes","role":"pseudoSymbol","id