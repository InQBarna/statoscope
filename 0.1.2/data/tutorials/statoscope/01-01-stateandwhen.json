{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen"},"kind":"project","variants":[{"paths":["\/tutorials\/statoscope\/01-01-stateandwhen"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"categoryPathComponent":"StatoscopeTutorial","category":"Statoscope Architecture","role":"project","title":"Create a simple Scope"},"hierarchy":{"paths":[["doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial","doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial\/$volume","doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial\/Tutorials"]],"reference":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial","modules":[{"reference":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial\/Tutorials","projects":[{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen","sections":[{"kind":"task","reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Create-a-scope"},{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Create-your-view","kind":"task"}]},{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects","sections":[{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects#What-is-a-side-effect","kind":"task"},{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects#Typed-effects","kind":"task"}]},{"sections":[{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware#Logging-middleware","kind":"task"},{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware#Built-in-Library-logging","kind":"task"}],"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware"},{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection","sections":[{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection#Designing-a-Dependency","kind":"task"}]},{"sections":[{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes#Designing-Scopes","kind":"task"},{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes#Views-and-Scopes","kind":"task"}],"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes"}]}]},"sections":[{"chapter":"Tutorials","estimatedTimeInMinutes":20,"title":"Create a simple Scope","kind":"hero","content":[{"inlineContent":[{"text":"Define a scope object with state member variables representing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a part of your app’s status, define the events that may affect"},{"type":"text","text":" "},{"text":"this state, and create a view to display the state.","type":"text"}],"type":"paragraph"}]},{"tasks":[{"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"text":"Scopes in Statoscope represent self-contained sections of your app’s logic, managing state and reacting to user or system-driven events. Each scope contains its own member variables to track state, an ","type":"text"},{"code":"update","type":"codeVoice"},{"text":" function to handle the defined events (called ","type":"text"},{"type":"codeVoice","code":"When"},{"type":"text","text":" cases), and can communicate with views or other components."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A simple use case is a counter, where we want to display the count value and allow the user to increment or decrement it by tapping buttons.","type":"text"}]}],"mediaPosition":"trailing"}],"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Create a file "},{"code":"Counter.swift","type":"codeVoice"},{"type":"text","text":" and import the Statoscope library. This is the first step towards creating your counter scope."},{"text":" ","type":"text"},{"type":"text","text":"Statoscope helps in defining your app’s state as a separate, modular component that can easily be tested."}],"type":"paragraph"}],"caption":[],"type":"step","code":"01-01-01-code-0001.swift","media":null,"runtimePreview":null},{"type":"step","media":null,"content":[{"inlineContent":[{"text":"Define your state using member variables.","type":"text"}],"type":"paragraph"}],"code":"01-01-01-code-0002.swift","runtimePreview":null,"caption":[{"inlineContent":[{"text":"We suggest using clear, sentence-like naming for state variables. This will make your code more readable and also simplify acceptance testing.","type":"text"}],"type":"paragraph"}]},{"caption":[{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"When"},{"text":" cases represent the events that trigger state changes. Again, using sentence-like names for these events ensures that your code is both readable and self-explanatory in tests.","type":"text"}],"type":"paragraph"}],"content":[{"type":"paragraph","inlineContent":[{"text":"Add the ","type":"text"},{"type":"codeVoice","code":"When"},{"text":" events that can occur in your scope.","type":"text"}]}],"runtimePreview":null,"media":null,"code":"01-01-01-code-0003.swift","type":"step"},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, define the "},{"type":"codeVoice","code":"update"},{"text":" method that will contain your business logic.","type":"text"}]}],"media":null,"runtimePreview":null,"caption":[{"inlineContent":[{"type":"text","text":"This method will be responsible for managing how your state evolves when events occur. For now, leave the method skeleton in place — we’ll return to it later."}],"type":"paragraph"}],"code":"01-01-01-code-0004.swift"},{"media":null,"type":"step","code":"01-01-01-code-0005.swift","caption":[{"inlineContent":[{"type":"text","text":"One of the main goals of the Statoscope architecture is to achieve"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"ACCEPTANCE AS CODE"}],"type":"strong"},{"text":". This means your tests will closely align with the user’s acceptance criteria, making the testing process more intuitive and reflective of real user scenarios.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"content":[{"inlineContent":[{"text":"Before building the real scope implementation via the ","type":"text"},{"code":"update","type":"codeVoice"},{"type":"text","text":" method,"},{"text":" ","type":"text"},{"text":"let’s take a look at how we can write acceptance tests for the","type":"text"},{"type":"text","text":" "},{"text":"current state’s scope.","type":"text"}],"type":"paragraph"}]},{"media":null,"content":[{"inlineContent":[{"type":"text","text":"You can try running the test now, but it will fail until we implement"},{"text":" ","type":"text"},{"type":"text","text":"the actual logic in the "},{"type":"codeVoice","code":"update"},{"type":"text","text":" method."}],"type":"paragraph"}],"type":"step","code":"01-01-01-code-0004.swift","caption":[],"runtimePreview":null},{"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now it’s time to implement the "},{"type":"codeVoice","code":"update"},{"text":" method, which contains the state maintenance and business logic of your app’s scope.","type":"text"}]}],"code":"01-01-01-code-0006.swift","caption":[{"inlineContent":[{"text":"For this counter example, the logic involves updating the count when the user taps either the increment or decrement button, ensuring that the count never drops below zero.","type":"text"}],"type":"paragraph"}],"type":"step","media":null},{"type":"step","runtimePreview":null,"code":"01-01-01-code-0007.swift","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We will soon create a view to display the state. Since we’ll be"},{"type":"text","text":" "},{"text":"using SwiftUI, adopt the ","type":"text"},{"type":"codeVoice","code":"ObservableObject"},{"type":"text","text":" protocol and use "},{"code":"@Published","type":"codeVoice"},{"text":"","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for the state variables that the view will observe and reflect."}]}],"caption":[]}],"title":"Create a scope","anchor":"Create-a-scope"},{"contentSection":[{"mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"Now that we’ve set up the scope, it’s time to build the view that will interact with this state. Using SwiftUI, we will create a simple view that displays the current count and provides buttons to increment or decrement the value. This will allow the user to interact with the scope’s state."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The view will automatically update when the state changes, thanks to the "},{"type":"codeVoice","code":"ObservableObject"},{"type":"text","text":" protocol and "},{"type":"codeVoice","code":"@Published"},{"text":" properties.","type":"text"}],"type":"paragraph"}],"kind":"contentAndMedia"}],"stepsSection":[{"runtimePreview":null,"caption":[],"code":"01-01-01-code-0008.swift","type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"Let’s create our view. SwiftUI’s declarative syntax will help you define this easily and make your source code straightforward."}],"type":"paragraph"}]},{"inlineContent":[{"text":"So far so good, we’ve built our first scope implementing a simple counter. The scope manages the state, the view displays it, and the user interacts with the scope through the UI.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Move to the next chapters to understand "},{"inlineContent":[{"text":"Effects","type":"text"}],"type":"strong"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"Scope composition","type":"text"}],"type":"strong"},{"text":", where we’ll expand the functionality and connect multiple scopes together for more complex app features.","type":"text"}]}],"title":"Create your view","anchor":"Create-your-view"}],"kind":"tasks"},{"action":{"type":"reference","overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"isActive":true,"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects"},"abstract":[{"type":"text","text":"Trigger effects that will get back to your scope as a new When event."}],"featuredEyebrow":"Tutorial","title":"State, When and Effects","kind":"callToAction"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects#Typed-effects":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects#Typed-effects","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects#Typed-effects","kind":"section","type":"section","role":"pseudoSymbol","abstract":[{"text":"Trigger effects that will get back to your scope as a new When event.","type":"text"}],"title":"Typed effects"},"01-01-01-code-0005.swift":{"type":"file","identifier":"01-01-01-code-0005.swift","content":["import StatoscopeTesting","","final class CounterTest: XCTestCase {","","    func testUserFlow() throws {","        try Counter.GIVEN {","            Counter()","        }","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .WHEN(.userTappedIncrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 1)","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .runTest()","    }","","}"],"highlights":[],"fileName":"CounterTests.swift","syntax":"swift","fileType":"swift"},"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects#What-is-a-side-effect":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects#What-is-a-side-effect","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects#What-is-a-side-effect","kind":"section","type":"section","role":"pseudoSymbol","abstract":[{"text":"Trigger effects that will get back to your scope as a new When event.","type":"text"}],"title":"What is a side effect?"},"doc://Statoscope/tutorials/Statoscope/01-04-Injection#Designing-a-Dependency":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection#Designing-a-Dependency","url":"\/tutorials\/statoscope\/01-04-injection#Designing-a-Dependency","kind":"section","type":"section","role":"pseudoSymbol","abstract":[{"text":"Learn how to easily design dependencies and inject them into your scopes. Dependency injection simplifies the structure of your code by externalizing the management of dependencies, making your code more modular, testable, and flexible. In this tutorial, we will demonstrate dependency injection using an example of a simple news feed application.","type":"text"}],"title":"Designing a Dependency"},"doc://Statoscope/tutorials/StatoscopeTutorial":{"kind":"overview","url":"\/tutorials\/statoscopetutorial","role":"overview","title":"Statoscope basics","type":"topic","identifier":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial","abstract":[{"text":"Statoscope is a small library to build apps with state management,","type":"text"},{"text":" ","type":"text"},{"text":"testing, effects management and dependency injection.","type":"text"}]},"doc://Statoscope/tutorials/Statoscope/01-01-StateAndWhen#Create-a-scope":{"kind":"section","url":"\/tutorials\/statoscope\/01-01-stateandwhen#Create-a-scope","role":"pseudoSymbol","title":"Create a scope","type":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Create-a-scope","abstract":[{"text":"Define a scope object with state member variables representing","type":"text"},{"text":" ","type":"text"},{"text":"a part of your app’s status, define the events that may affect","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this state, and create a view to display the state."}]},"doc://Statoscope/tutorials/Statoscope/01-05-Scopes":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes","url":"\/tutorials\/statoscope\/01-05-scopes","kind":"project","type":"topic","role":"project","abstract":[{"text":"In complex applications, managing all state and events in a single Statostore quickly becomes unsustainable. To scale effectively, we need to split the app’s state and events into separate parts or Scopes. This process can sometimes be straightforward, but other times, developers may feel compelled to separate state and events that are closely tied together due to business logic. In this tutorial, we’ll focus on how to organize app state into different scopes to maintain scalability.","type":"text"}],"title":"Scopes","estimatedTime":"30min"},"doc://Statoscope/tutorials/Statoscope/01-05-Scopes#Designing-Scopes":{"abstract":[{"type":"text","text":"In complex applications, managing all state and events in a single Statostore quickly becomes unsustainable. To scale effectively, we need to split the app’s state and events into separate parts or Scopes. This process can sometimes be straightforward, but other times, developers may feel compelled to separate state and events that are closely tied together due to business logic. In this tutorial, we’ll focus on how to organize app state into different scopes to maintain scalability."}],"type":"section","title":"Designing Scopes","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes#Designing-Scopes","kind":"section","role":"pseudoSymbol","url":"\/tutorials\/statoscope\/01-05-scopes#Designing-Scopes"},"doc://Statoscope/tutorials/Statoscope/01-01-StateAndWhen#Create-your-view":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Create-your-view","url":"\/tutorials\/statoscope\/01-01-stateandwhen#Create-your-view","kind":"section","type":"section","role":"pseudoSymbol","abstract":[{"text":"Define a scope object with state member variables representing","type":"text"},{"text":" ","type":"text"},{"text":"a part of your app’s status, define the events that may affect","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this state, and create a view to display the state."}],"title":"Create your view"},"doc://Statoscope/tutorials/Statoscope/01-05-Scopes#Views-and-Scopes":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes#Views-and-Scopes","url":"\/tutorials\/statoscope\/01-05-scopes#Views-and-Scopes","kind":"section","type":"section","role":"pseudoSymbol","abstract":[{"text":"In complex applications, managing all state and events in a single Statostore quickly becomes unsustainable. To scale effectively, we need to split the app’s state and events into separate parts or Scopes. This process can sometimes be straightforward, but other times, developers may feel compelled to separate state and events that are closely tied together due to business logic. In this tutorial, we’ll focus on how to organize app state into different scopes to maintain scalability.","type":"text"}],"title":"Views and Scopes"},"doc://Statoscope/tutorials/Statoscope/01-04-Injection":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection","url":"\/tutorials\/statoscope\/01-04-injection","kind":"project","type":"topic","role":"project","abstract":[{"text":"Learn how to easily design dependencies and inject them into your scopes. Dependency injection simplifies the structure of your code by externalizing the management of dependencies, making your code more modular, testable, and flexible. In this tutorial, we will demonstrate dependency injection using an example of a simple news feed application.","type":"text"}],"title":"Dependency Injection","estimatedTime":"30min"},"01-01-01-code-0004.swift":{"type":"file","identifier":"01-01-01-code-0004.swift","content":["import Statoscope","","private final class Counter: Scope {","","    var viewDisplaysTotalCount: Int = 0","","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","    }","","    func update(_ when: When) throws {","        \/\/ TODO","    }","}"],"highlights":[],"fileName":"Counter.swift","syntax":"swift","fileType":"swift"},"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects","kind":"project","type":"topic","role":"project","abstract":[{"text":"Trigger effects that will get back to your scope as a new When event.","type":"text"}],"title":"State, When and Effects","estimatedTime":"30min"},"01-01-01-code-0003.swift":{"fileName":"Counter.swift","fileType":"swift","type":"file","highlights":[{"line":6},{"line":7},{"line":8},{"line":9},{"line":10}],"identifier":"01-01-01-code-0003.swift","syntax":"swift","content":["import Statoscope","","private final class Counter: Scope {","","    var viewDisplaysTotalCount: Int = 0","","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","    }","}"]},"01-01-01-code-0006.swift":{"type":"file","identifier":"01-01-01-code-0006.swift","content":["import Statoscope","","private final class Counter: Scope {","","    var viewDisplaysTotalCount: Int = 0","","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","    }","","    func update(_ when: When) throws {","        switch when {","        case .userTappedIncrementButton:","            viewDisplaysTotalCount += 1","        case .userTappedDecrementButton:","            viewDisplaysTotalCount = max(0, viewDisplaysTotalCount - 1)","        }","    }","}"],"highlights":[{"line":13},{"line":14},{"line":15},{"line":16},{"line":17},{"line":18}],"fileName":"Counter.swift","syntax":"swift","fileType":"swift"},"doc://Statoscope/tutorials/Statoscope/01-03-Middleware#Built-in-Library-logging":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware#Built-in-Library-logging","url":"\/tutorials\/statoscope\/01-03-middleware#Built-in-Library-logging","kind":"section","type":"section","role":"pseudoSymbol","abstract":[{"text":"Understand how the single entry point enables pretty interesting features","type":"text"}],"title":"Built-in Library logging"},"01-01-01-code-0007.swift":{"type":"file","identifier":"01-01-01-code-0007.swift","content":["import Statoscope","","private final class Counter: Scope, ObservableObject {","","    @Published var viewDisplaysTotalCount: Int = 0","","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","    }","","    func update(_ when: When) throws {","        switch when {","        case .userTappedIncrementButton:","            viewDisplaysTotalCount += 1","        case .userTappedDecrementButton:","            viewDisplaysTotalCount = max(0, viewDisplaysTotalCount - 1)","        }","    }","}"],"highlights":[{"line":3},{"line":5}],"fileName":"Counter.swift","syntax":"swift","fileType":"swift"},"doc://Statoscope/tutorials/StatoscopeTutorial/Tutorials":{"kind":"article","url":"\/tutorials\/statoscopetutorial\/tutorials","role":"article","title":"Tutorials","type":"topic","identifier":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial\/Tutorials","abstract":[]},"doc://Statoscope/tutorials/Statoscope/01-03-Middleware#Logging-middleware":{"kind":"section","url":"\/tutorials\/statoscope\/01-03-middleware#Logging-middleware","role":"pseudoSymbol","title":"Logging middleware","type":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware#Logging-middleware","abstract":[{"text":"Understand how the single entry point enables pretty interesting features","type":"text"}]},"01-01-01-code-0002.swift":{"type":"file","identifier":"01-01-01-code-0002.swift","content":["import Statoscope","","private final class Counter: Scope {","","    var viewDisplaysTotalCount: Int = 0","}"],"highlights":[{"line":2},{"line":3},{"line":4},{"line":5},{"line":6}],"fileName":"Counter.swift","syntax":"swift","fileType":"swift"},"01-01-01-code-0008.swift":{"type":"file","identifier":"01-01-01-code-0008.swift","content":["import Statoscope","import SwiftUI","","private struct CounterView: View {","    @StateObject var model = Counter()","    var body: some View {","        VStack {","            Text(\"\\(model.viewDisplaysTotalCount)\")","            HStack {","                Button(\"+\") {","                    model.send(.userTappedIncrementButton)","                }","                Button(\"-\") {","                    model.send(.userTappedDecrementButton)","                }","            }","        }","    }","}"],"highlights":[],"fileName":"CounterView.swift","syntax":"swift","fileType":"swift"},"doc://Statoscope/tutorials/Statoscope/01-03-Middleware":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware","url":"\/tutorials\/statoscope\/01-03-middleware","kind":"project","type":"topic","role":"project","abstract":[{"text":"Understand how the single entry point enables pretty interesting features","type":"text"}],"title":"Single entry point and\/or middlewares","estimatedTime":"30min"},"01-01-01-code-0001.swift":{"type":"file","identifier":"01-01-01-code-0001.swift","content":["import Statoscope"],"highlights":[],"fileName":"Counter.swift","syntax":"swift","fileType":"swift"},"doc://Statoscope/tutorials/Statoscope/01-01-StateAndWhen":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen","url":"\/tutorials\/statoscope\/01-01-stateandwhen","kind":"project","type":"topic","role":"project","abstract":[{"text":"Define a scope object with state member variables representing","type":"text"},{"text":" ","type":"text"},{"text":"a part of your app’s status, define the events that may affect","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this state, and create a view to display the state."}],"title":"Create a simple Scope","estimatedTime":"20min"}}}