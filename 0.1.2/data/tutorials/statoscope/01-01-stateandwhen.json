ics","kind":"overview"},"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects":{"type":"topic","role":"project","abstract":[{"type":"text","text":"Trigger effects that will get back to your scope as a new When event."}],"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects","estimatedTime":"30min","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects","kind":"project","title":"State, When and Effects"},"StateAndWhen-CounterTests-04.swift":{"syntax":"swift","type":"file","content":["import StatoscopeTesting","","final class CounterTest: XCTestCase {","","    func testUserFlow() throws {","        try Counter.GIVEN {","            Counter()","        }","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .WHEN(.userTappedIncrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 1)","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .runTest()","    }","","}"],"identifier":"StateAndWhen-CounterTests-04.swift","fileName":"CounterTests.swift","highlights":[{"line":16}],"fileType":"swift"},"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects#What-is-a-side-effect":{"type":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Trigger effects that will get back to your scope as a new When event."}],"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects#What-is-a-side-effect","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects#What-is-a-side-effect","kind":"section","title":"What is a side effect?"},"StateAndWhen-CounterView-03.swift":{"syntax":"","type":"file","content":["import Statoscope","import SwiftUI","","struct CounterView: View {","    @ObservedObject var model = Counter()","    var body: some View {","        CounterViewDecoupled(","            viewDisplaysTotalCount: \"\\(model.viewDisplaysTotalCount)\",","            action: { model.send($0) }","        )","    }","}","","struct CounterViewDecoupled: View {","    let viewDisplaysTotalCount: String","    let action: (Counter.When) -> Void","    var body: some View {","        VStack {","            Text(viewDisplaysTotalCount)","            HStack {","                Button(\"+\") {","                    action(.userTappedIncrementButton)","                }","                Button(\"-\") {","                    action(.userTappedDecrementButton)","                }","            }","        }","    }","}"],"identifier":"StateAndWhen-CounterView-03.swift","fileName":"CounterViewDecoupled","highlights":[],"fileType":""},"StateAndWhen-Counter-02.swift":{"type":"file","syntax":"swift","content":["import Statoscope","","private final class Counter: Scope {","","    var viewDisplaysTotalCount: Int = 0","}"],"identifier":"StateAndWhen-Counter-02.swift","fileName":"Counter.swift","highlights":[],"fileType":"swift"},"doc://Statoscope/tutorials/Statoscope/01-01-StateAndWhen#Create-a-scope":{"type":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Define a scope object with state member variables representing"},{"type":"text","text":" "},{"text":"a part of your app’s status, define the events that may affect","type":"text"},{"type":"text","text":" "},{"text":"this state, and create a view to display the state.","type":"text"}],"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Create-a-scope","url":"\/tutorials\/statoscope\/01-01-stateandwhen#Create-a-scope","kind":"section","title":"Create a scope"},"StateAndWhen-Counter-03.swift":{"content":["import Statoscope","","private final class Counter: Scope {","","    var viewDisplaysTotalCount: Int = 0","","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","    }","}"],"fileName":"Counter.swift","highlights":[{"line":6},{"line":7},{"line":8},{"line":9},{"line":10}],"identifier