{"sections":[{"title":"State, When and Effects","estimatedTimeInMinutes":30,"content":[{"inlineContent":[{"text":"Trigger effects that will get back to your scope as a new When event.","type":"text"}],"type":"paragraph"}],"kind":"hero","chapter":"Tutorials"},{"tasks":[{"stepsSection":[{"type":"step","media":null,"caption":[{"inlineContent":[{"type":"text","text":"Please not how a network call has been splitted into 2 different When events: the"},{"text":" ","type":"text"},{"type":"text","text":"trigger and the resulting synchronous action “networkPostCompleted(DTO)”. This"},{"text":" ","type":"text"},{"type":"text","text":"way we can continue to work on the synchrnous update + expect policy, core to"},{"type":"text","text":" "},{"type":"text","text":"the Statoscope library."}],"type":"paragraph"}],"content":[{"inlineContent":[{"text":"Let’s start by looking at the acceptance criteria to understand this new","type":"text"},{"type":"text","text":" "},{"type":"text","text":"example. We’ll basically build a counter that is stored remotely via a"},{"type":"text","text":" "},{"type":"text","text":"network API to save the current state of the counter."},{"type":"text","text":" "},{"type":"text","text":"We may solve the posting \/ synchronization in many different ways. We expect"},{"type":"text","text":" "},{"text":"the ACCEPTANCE AS CODE in CloudCounterTests to explain the behavoiur selected","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for this example."}],"type":"paragraph"}],"code":"01-02-01-code-0001.swift","runtimePreview":null},{"code":"01-02-01-code-0002.swift","media":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"We added the CloudCounter class in the acceptance definition for completeness.","type":"text"},{"text":" ","type":"text"},{"text":"Now move the CloudCounter to its own a file CloudCounter.swift.","type":"text"}]}],"type":"step","caption":[]},{"caption":[],"media":null,"code":"01-02-01-code-0003.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Part of our business logic needs to make a post request to a network service."},{"text":" ","type":"text"},{"type":"text","text":"As a first step we will build the synchronous logic and leave the postNewValueToNetwork"},{"text":" ","type":"text"},{"text":"unimplemented.","type":"text"}]}],"runtimePreview":null,"type":"step"},{"code":"01-02-01-code-0004.swift","type":"step","media":null,"runtimePreview":null,"caption":[{"inlineContent":[{"type":"text","text":"We need to use the concurrency framework to connect Effects to the Statoscope"},{"text":" ","type":"text"},{"type":"text","text":"library. So implement your request using an async method that returns a new When case"},{"type":"text","text":" "},{"type":"text","text":"as the asynchronous result of our effect"}],"type":"paragraph"}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"And now add an effect by using the enqueue method in the ScopeImplementation protocol."}]}]},{"type":"paragraph","inlineContent":[{"text":"Nice! We’ve created our first scope with effects.","type":"text"}]}],"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"text":"Side effect is the name given to executed code that results in a later or unclear","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"behaviour. As developers, we expect these side effects to be as less as possible, except"},{"type":"text","text":" "},{"text":"for a group of them that are fully expected: the asynchronous tasks. In the current","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example we will work on the most common async tasks nowadays: network requests, and we"},{"text":" ","type":"text"},{"text":"will clearly state how they behave and adopt the Statoscope update protocol.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing"}],"anchor":"What-is-a-side-effect","title":"What is a side effect?"},{"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"In the previous section, we enqueued and anonymous effect. However we strongly recommend"},{"text":" ","type":"text"},{"type":"text","text":"to work with typed effects in production code to achieve testability, cancellability and"},{"text":" ","type":"text"},{"text":"observability. Let’s dive into typed effects.","type":"text"}],"type":"paragraph"}]}],"anchor":"Typed-effects","title":"Typed effects","stepsSection":[{"type":"step","caption":[],"media":null,"code":"01-02-02-code-0001.swift","content":[{"inlineContent":[{"text":"Create an subclass of Effect that provides a network request execution.","type":"text"}],"type":"paragraph"}],"runtimePreview":null},{"content":[{"inlineContent":[{"text":"Now go back to our CloudCounter implementation.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"code":"01-02-01-code-0004.swift","media":null,"type":"step","caption":[]},{"code":"01-02-02-code-0002.swift","runtimePreview":null,"content":[{"inlineContent":[{"text":"And change the anonymous enqueue to use the typed enqueuing.","type":"text"}],"type":"paragraph"}],"caption":[],"type":"step","media":null},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"NOW: you can benefit of observability and cancellation. Please see how we"},{"type":"text","text":" "},{"type":"text","text":"can check if the effect is already running and (if desired) we can cancel it."}]}],"caption":[],"type":"step","runtimePreview":null,"code":"01-02-02-code-0003.swift"},{"caption":[],"type":"step","media":null,"code":"01-02-02-code-0004.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s go back to our testing code before ending this section"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"When Effects are typed, they can be included in our testing code, to check","type":"text"},{"text":" ","type":"text"},{"text":"which effects are being enqueued, as part of our checks.","type":"text"}]}],"type":"step","caption":[],"runtimePreview":null,"media":null,"code":"01-02-02-code-0005.swift"}]}],"kind":"tasks"},{"kind":"callToAction","title":"Single entry point and\/or middlewares","featuredEyebrow":"Tutorial","abstract":[{"type":"text","text":"Understand how the single entry point enables pretty interesting features"}],"action":{"identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware","overridingTitle":"Get started","isActive":true,"type":"reference","overridingTitleInlineContent":[{"text":"Get started","type":"text"}]}}],"metadata":{"title":"State, When and Effects","categoryPathComponent":"StatoscopeTutorial","category":"Statoscope Architecture","role":"project"},"kind":"project","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/statoscope\/01-02-statewhenandeffects"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects","interfaceLanguage":"swift"},"hierarchy":{"reference":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial","modules":[{"reference":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial\/Tutorials","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Create-a-scope"},{"kind":"task","reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Create-your-view"}],"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen"},{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects","sections":[{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects#What-is-a-side-effect","kind":"task"},{"kind":"task","reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects#Typed-effects"}]},{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware","sections":[{"kind":"task","reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware#Logging-middleware"},{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware#Built-in-Library-logging","kind":"task"}]},{"sections":[{"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection#Designing-a-Dependency","kind":"task"}],"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection"},{"sections":[{"kind":"task","reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes#Design-scopes"},{"kind":"task","reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes#Views-and-scopes"}],"reference":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes"}]}],"paths":[["doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial","doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial\/$volume","doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial\/Tutorials"]]},"references":{"01-02-01-code-0003.swift":{"content":["import Statoscope","","struct DTO: Codable {","    let count: Int","}","","final class CloudCounter: ScopeImplementation {","    var viewDisplaysTotalCount: Int = 0","    var viewShowsLoadingAndDisablesButtons: Bool = false","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","        case networkPostCompleted(DTO)","    }","","    func update(_ when: When) throws {","        switch when {","        case .userTappedIncrementButton:","            viewDisplaysTotalCount = viewDisplaysTotalCount + 1","            viewShowsLoadingAndDisablesButtons = true","            try postNewValueToNetwork(newValue: viewDisplaysTotalCount)","        case .userTappedDecrementButton:","            guard viewDisplaysTotalCount > 0 else {","                return","            }","            viewDisplaysTotalCount = viewDisplaysTotalCount - 1","            viewShowsLoadingAndDisablesButtons = true","            try postNewValueToNetwork(newValue: viewDisplaysTotalCount)","        case .networkPostCompleted(let remoteCounter):","            viewShowsLoadingAndDisablesButtons = false","            viewDisplaysTotalCount = remoteCounter.count","        }","    }","    ","    private func postNewValueToNetwork(newValue: Int) throws {","        \/\/ TODO post the new value to the network","    }","}"],"fileType":"swift","type":"file","fileName":"CloudCounter.swift","highlights":[{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29},{"line":30},{"line":31},{"line":32},{"line":33},{"line":34},{"line":35},{"line":36},{"line":37}],"syntax":"swift","identifier":"01-02-01-code-0003.swift"},"01-02-02-code-0003.swift":{"identifier":"01-02-02-code-0003.swift","fileName":"CloudCounter.swift","content":["import Statoscope","","enum Network {","    static func buildURLRequestPosting(dto: DTO) throws -> URLRequest {","        guard let url = URL(string: \"http:\/\/statoscope.com\") else {","            throw Error()","        }","        var request = URLRequest(url: url)","        request.setValue(\"application\/json\", forHTTPHeaderField: \"Content-Type\")","        request.httpMethod = \"POST\"","        request.httpBody = try JSONEncoder().encode(dto)","        return request","    }","}","","struct DTO: Codable {","    let count: Int","}","","final class CloudCounter: ScopeImplementation {","    var viewDisplaysTotalCount: Int = 0","    var viewShowsLoadingAndDisablesButtons: Bool = false","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","        case networkPostCompleted(DTO)","    }","","    func update(_ when: When) throws {","        switch when {","        case .userTappedIncrementButton:","            viewDisplaysTotalCount = viewDisplaysTotalCount + 1","            viewShowsLoadingAndDisablesButtons = true","            try postNewValueToNetwork(newValue: viewDisplaysTotalCount)","        case .userTappedDecrementButton:","            guard viewDisplaysTotalCount > 0 else {","                return","            }","            viewDisplaysTotalCount = viewDisplaysTotalCount - 1","            viewShowsLoadingAndDisablesButtons = true","            try postNewValueToNetwork(newValue: viewDisplaysTotalCount)","        case .networkPostCompleted(let remoteCounter):","            viewShowsLoadingAndDisablesButtons = false","            viewDisplaysTotalCount = remoteCounter.count","        }","    }","    ","    private func postNewValueToNetwork(newValue: Int) throws {","        ","        \/\/ Solution 1: cancel any previous network effect","        effectsState.cancelEffect { $0 is NetworkEffect<DTO> }","        ","        \/\/ Solution 2: do nothing if an effect is already running","        guard nil == effects.first(where: { $0 is NetworkEffect<DTO> }) else {","            throw InvalidStateError()","        }","        ","        enqueue(","            Network.Effect<DTO>(request: try Network.buildURLRequestPosting(dto: DTO(count: newValue)))","                .map(When.networkPostCompleted)","        )","    }","}"],"type":"file","fileType":"swift","highlights":[{"line":48},{"line":49},{"line":50},{"line":51},{"line":52},{"line":53},{"line":54},{"line":55},{"line":56},{"line":57},{"line":58}],"syntax":"swift"},"doc://Statoscope/tutorials/StatoscopeTutorial":{"role":"overview","identifier":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial","url":"\/tutorials\/statoscopetutorial","type":"topic","title":"Statoscope basics","abstract":[{"text":"Statoscope is a small library to build apps with state management,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"testing, effects management and dependency injection."}],"kind":"overview"},"01-02-02-code-0004.swift":{"identifier":"01-02-02-code-0004.swift","fileName":"CloudCounterTests.swift","content":["import StatoscopeTesting","","final class CloudCounterTest: XCTestCase {","","    func testUserFlow() throws {","        ","        var expectedNetworkRequest = URLRequest(url: try XCTUnwrap(URL(string: \"http:\/\/statoscope.com\")))","        expectedNetworkRequest.setValue(\"application\/json\", forHTTPHeaderField: \"Content-Type\")","        expectedNetworkRequest.httpMethod = \"POST\"","        expectedNetworkRequest.httpBody = try JSONEncoder().encode(DTO(count: 0))","        ","        try CloudCounter.GIVEN {","            CloudCounter()","        }","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: false)","        \/\/ Increment","        .WHEN(.userTappedIncrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 1)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: true)","        .WHEN(.networkPostCompleted(DTO(count: 1)))","        .THEN(\\.viewDisplaysTotalCount, equals: 1)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: false)","        \/\/ Decrement","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: true)","        .WHEN(.networkPostCompleted(DTO(count: 0)))","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: false)","        \/\/ Invalid decrement","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .runTest()","    }","","}"],"type":"file","fileType":"swift","highlights":[],"syntax":"swift"},"doc://Statoscope/tutorials/Statoscope/01-01-StateAndWhen#Create-a-scope":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"Define a scope object with state member variables representing"},{"type":"text","text":" "},{"text":"a part of your app’s status, define the events that may affect","type":"text"},{"type":"text","text":" "},{"text":"this state, and create a view to display the state.","type":"text"}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Create-a-scope","type":"section","url":"\/tutorials\/statoscope\/01-01-stateandwhen#Create-a-scope","title":"Create a scope"},"doc://Statoscope/tutorials/Statoscope/01-05-Scopes":{"role":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes","estimatedTime":"30min","url":"\/tutorials\/statoscope\/01-05-scopes","type":"topic","title":"Scopes","abstract":[{"text":"Defining all state and When events in a single Statostore doesn’t scale. We need to decide where exactly to split our state and events into separate state parts or Scopes. Sometimes separation is obvious and sometimes developers want to separate state and events that are inevitably coupled due to the nature of the business logic. However, this article will focus in how to separate the state of our apps in different scopes.","type":"text"}],"kind":"project"},"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects":{"role":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects","estimatedTime":"30min","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects","type":"topic","title":"State, When and Effects","abstract":[{"type":"text","text":"Trigger effects that will get back to your scope as a new When event."}],"kind":"project"},"doc://Statoscope/tutorials/Statoscope/01-05-Scopes#Views-and-scopes":{"role":"pseudoSymbol","abstract":[{"text":"Defining all state and When events in a single Statostore doesn’t scale. We need to decide where exactly to split our state and events into separate state parts or Scopes. Sometimes separation is obvious and sometimes developers want to separate state and events that are inevitably coupled due to the nature of the business logic. However, this article will focus in how to separate the state of our apps in different scopes.","type":"text"}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes#Views-and-scopes","type":"section","url":"\/tutorials\/statoscope\/01-05-scopes#Views-and-scopes","title":"Views and scopes"},"01-02-01-code-0001.swift":{"identifier":"01-02-01-code-0001.swift","fileName":"CloudCounterTests.swift","content":["import StatoscopeTesting","","struct DTO: Codable {","    let count: Int","}","","final class CloudCounter: ScopeImplementation {","    var viewDisplaysTotalCount: Int = 0","    var viewShowsLoadingAndDisablesButtons: Bool = false","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","        case networkPostCompleted(DTO)","    }","","    func update(_ when: When) throws {}","}","","final class CloudCounterTest: XCTestCase {","","    func testUserFlow() throws {","        try CloudCounter.GIVEN {","            CloudCounter()","        }","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: false)","        \/\/ Increment","        .WHEN(.userTappedIncrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 1)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: true)","        .WHEN(.networkPostCompleted(DTO(count: 1)))","        .THEN(\\.viewDisplaysTotalCount, equals: 1)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: false)","        \/\/ Decrement","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: true)","        .WHEN(.networkPostCompleted(DTO(count: 0)))","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: false)","        \/\/ Invalid decrement","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .runTest()","    }","","}"],"type":"file","fileType":"swift","highlights":[],"syntax":"swift"},"01-02-02-code-0005.swift":{"identifier":"01-02-02-code-0005.swift","fileName":"CloudCounterTests.swift","content":["import StatoscopeTesting","","final class CloudCounterTest: XCTestCase {","","    func testUserFlow() throws {","        ","        var expectedNetworkRequest = URLRequest(url: try XCTUnwrap(URL(string: \"http:\/\/statoscope.com\")))","        expectedNetworkRequest.setValue(\"application\/json\", forHTTPHeaderField: \"Content-Type\")","        expectedNetworkRequest.httpMethod = \"POST\"","        expectedNetworkRequest.httpBody = try JSONEncoder().encode(DTO(count: 0))","        ","        try CloudCounter.GIVEN {","            CloudCounter()","        }","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: false)","        \/\/ Increment","        .WHEN(.userTappedIncrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 1)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: true)","        .THEN_EnquedEffect(Network.Effect<DTO>(request: expectedNetworkRequest))","        .WHEN(.networkPostCompleted(DTO(count: 1)))","        .THEN(\\.viewDisplaysTotalCount, equals: 1)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: false)","        .THEN { XCTAssertEqual($0.effects.count, 0) }","        \/\/ Decrement","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: true)","        .WHEN(.networkPostCompleted(DTO(count: 0)))","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .THEN(\\.viewShowsLoadingAndDisablesButtons, equals: false)","        \/\/ Invalid decrement","        .WHEN(.userTappedDecrementButton)","        .THEN(\\.viewDisplaysTotalCount, equals: 0)","        .runTest()","    }","","}"],"type":"file","fileType":"swift","highlights":[{"line":21},{"line":25}],"syntax":"swift"},"01-02-02-code-0001.swift":{"identifier":"01-02-02-code-0001.swift","fileName":"NetworkEffect.swift","content":["import Statoscope","","extension Network {","    struct Effect<Response: Decodable>: Effect {","        let request: URLRequest","        func runEffect() async throws -> Response {","            try JSONDecoder().decode(Response.self, from: try await URLSession.shared.data(for: request).0)","        }","    }","}"],"type":"file","fileType":"swift","highlights":[],"syntax":"swift"},"doc://Statoscope/tutorials/Statoscope/01-03-Middleware":{"role":"project","abstract":[{"text":"Understand how the single entry point enables pretty interesting features","type":"text"}],"kind":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware","type":"topic","estimatedTime":"30min","url":"\/tutorials\/statoscope\/01-03-middleware","title":"Single entry point and\/or middlewares"},"doc://Statoscope/tutorials/Statoscope/01-03-Middleware#Built-in-Library-logging":{"title":"Built-in Library logging","abstract":[{"type":"text","text":"Understand how the single entry point enables pretty interesting features"}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware#Built-in-Library-logging","type":"section","url":"\/tutorials\/statoscope\/01-03-middleware#Built-in-Library-logging","role":"pseudoSymbol"},"doc://Statoscope/tutorials/StatoscopeTutorial/Tutorials":{"title":"Tutorials","abstract":[],"kind":"article","identifier":"doc:\/\/Statoscope\/tutorials\/StatoscopeTutorial\/Tutorials","type":"topic","url":"\/tutorials\/statoscopetutorial\/tutorials","role":"article"},"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects#What-is-a-side-effect":{"title":"What is a side effect?","abstract":[{"type":"text","text":"Trigger effects that will get back to your scope as a new When event."}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects#What-is-a-side-effect","type":"section","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects#What-is-a-side-effect","role":"pseudoSymbol"},"doc://Statoscope/tutorials/Statoscope/01-01-StateAndWhen":{"title":"Create a simple Scope","estimatedTime":"20min","abstract":[{"type":"text","text":"Define a scope object with state member variables representing"},{"text":" ","type":"text"},{"text":"a part of your app’s status, define the events that may affect","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this state, and create a view to display the state."}],"kind":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen","type":"topic","url":"\/tutorials\/statoscope\/01-01-stateandwhen","role":"project"},"doc://Statoscope/tutorials/Statoscope/01-03-Middleware#Logging-middleware":{"title":"Logging middleware","abstract":[{"type":"text","text":"Understand how the single entry point enables pretty interesting features"}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-03-Middleware#Logging-middleware","type":"section","url":"\/tutorials\/statoscope\/01-03-middleware#Logging-middleware","role":"pseudoSymbol"},"doc://Statoscope/tutorials/Statoscope/01-05-Scopes#Design-scopes":{"role":"pseudoSymbol","abstract":[{"text":"Defining all state and When events in a single Statostore doesn’t scale. We need to decide where exactly to split our state and events into separate state parts or Scopes. Sometimes separation is obvious and sometimes developers want to separate state and events that are inevitably coupled due to the nature of the business logic. However, this article will focus in how to separate the state of our apps in different scopes.","type":"text"}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-05-Scopes#Design-scopes","type":"section","url":"\/tutorials\/statoscope\/01-05-scopes#Design-scopes","title":"Design scopes"},"doc://Statoscope/tutorials/Statoscope/01-04-Injection#Designing-a-Dependency":{"title":"Designing a Dependency","abstract":[{"type":"text","text":"Learn how to easily design dependencies and inject them into your scopes. Dependency injection simplifies the structure of your code by externalizing the management of dependencies, making your code more modular, testable, and flexible. In this tutorial, we will demonstrate dependency injection using an example of a simple news feed application."}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection#Designing-a-Dependency","type":"section","url":"\/tutorials\/statoscope\/01-04-injection#Designing-a-Dependency","role":"pseudoSymbol"},"doc://Statoscope/tutorials/Statoscope/01-01-StateAndWhen#Create-your-view":{"title":"Create your view","abstract":[{"type":"text","text":"Define a scope object with state member variables representing"},{"type":"text","text":" "},{"text":"a part of your app’s status, define the events that may affect","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this state, and create a view to display the state."}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-01-StateAndWhen#Create-your-view","type":"section","url":"\/tutorials\/statoscope\/01-01-stateandwhen#Create-your-view","role":"pseudoSymbol"},"01-02-01-code-0002.swift":{"content":["import Statoscope","","struct DTO: Codable {","    let count: Int","}","","final class CloudCounter: ScopeImplementation {","    var viewDisplaysTotalCount: Int = 0","    var viewShowsLoadingAndDisablesButtons: Bool = false","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","        case networkPostCompleted(DTO)","    }","","    func update(_ when: When) throws {}","}"],"fileType":"swift","type":"file","fileName":"CloudCounter.swift","highlights":[],"syntax":"swift","identifier":"01-02-01-code-0002.swift"},"doc://Statoscope/tutorials/Statoscope/01-02-StateWhenAndEffects#Typed-effects":{"title":"Typed effects","abstract":[{"type":"text","text":"Trigger effects that will get back to your scope as a new When event."}],"kind":"section","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-02-StateWhenAndEffects#Typed-effects","type":"section","url":"\/tutorials\/statoscope\/01-02-statewhenandeffects#Typed-effects","role":"pseudoSymbol"},"doc://Statoscope/tutorials/Statoscope/01-04-Injection":{"title":"Dependency Injection","estimatedTime":"30min","abstract":[{"type":"text","text":"Learn how to easily design dependencies and inject them into your scopes. Dependency injection simplifies the structure of your code by externalizing the management of dependencies, making your code more modular, testable, and flexible. In this tutorial, we will demonstrate dependency injection using an example of a simple news feed application."}],"kind":"project","identifier":"doc:\/\/Statoscope\/tutorials\/Statoscope\/01-04-Injection","type":"topic","url":"\/tutorials\/statoscope\/01-04-injection","role":"project"},"01-02-01-code-0004.swift":{"identifier":"01-02-01-code-0004.swift","fileName":"CloudCounter.swift","content":["import Statoscope","","enum Network {","    static func buildURLRequestPosting(dto: DTO) throws -> URLRequest {","        guard let url = URL(string: \"http:\/\/statoscope.com\") else {","            throw InvalidStateError()","        }","        var request = URLRequest(url: url)","        request.setValue(\"application\/json\", forHTTPHeaderField: \"Content-Type\")","        request.httpMethod = \"POST\"","        request.httpBody = try JSONEncoder().encode(dto)","        return request","    }","}","","struct DTO: Codable {","    let count: Int","}","","final class CloudCounter: ScopeImplementation {","    var viewDisplaysTotalCount: Int = 0","    var viewShowsLoadingAndDisablesButtons: Bool = false","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","        case networkPostCompleted(DTO)","    }","","    func update(_ when: When) throws {","        switch when {","        case .userTappedIncrementButton:","            viewDisplaysTotalCount = viewDisplaysTotalCount + 1","            viewShowsLoadingAndDisablesButtons = true","            try postNewValueToNetwork(newValue: viewDisplaysTotalCount)","        case .userTappedDecrementButton:","            guard viewDisplaysTotalCount > 0 else {","                return","            }","            viewDisplaysTotalCount = viewDisplaysTotalCount - 1","            viewShowsLoadingAndDisablesButtons = true","            try postNewValueToNetwork(newValue: viewDisplaysTotalCount)","        case .networkPostCompleted(let remoteCounter):","            viewShowsLoadingAndDisablesButtons = false","            viewDisplaysTotalCount = remoteCounter.count","        }","    }","    ","    private func postNewValueToNetwork(newValue: Int) throws {","        effectsState.enqueue(","            AnyEffect {","                let request = try Network.buildURLRequestPosting(dto: DTO(count: self.viewDisplaysTotalCount))","                let resDTO = try JSONDecoder().decode(DTO.self, from: try await URLSession.shared.data(for: request).0)","                return When.networkPostCompleted(resDTO)","            }","        )","    }","}"],"type":"file","fileType":"swift","highlights":[],"syntax":"swift"},"01-02-02-code-0002.swift":{"identifier":"01-02-02-code-0002.swift","fileName":"CloudCounter.swift","content":["import Statoscope","","enum Network {","    static func buildURLRequestPosting(dto: DTO) throws -> URLRequest {","        guard let url = URL(string: \"http:\/\/statoscope.com\") else {","            throw Error()","        }","        var request = URLRequest(url: url)","        request.setValue(\"application\/json\", forHTTPHeaderField: \"Content-Type\")","        request.httpMethod = \"POST\"","        request.httpBody = try JSONEncoder().encode(dto)","        return request","    }","}","","struct DTO: Codable {","    let count: Int","}","","final class CloudCounter: ScopeImplementation {","    var viewDisplaysTotalCount: Int = 0","    var viewShowsLoadingAndDisablesButtons: Bool = false","    enum When {","        case userTappedIncrementButton","        case userTappedDecrementButton","        case networkPostCompleted(DTO)","    }","","    func update(_ when: When) throws {","        switch when {","        case .userTappedIncrementButton:","            viewDisplaysTotalCount = viewDisplaysTotalCount + 1","            viewShowsLoadingAndDisablesButtons = true","            try postNewValueToNetwork(newValue: viewDisplaysTotalCount)","        case .userTappedDecrementButton:","            guard viewDisplaysTotalCount > 0 else {","                return","            }","            viewDisplaysTotalCount = viewDisplaysTotalCount - 1","            viewShowsLoadingAndDisablesButtons = true","            try postNewValueToNetwork(newValue: viewDisplaysTotalCount)","        case .networkPostCompleted(let remoteCounter):","            viewShowsLoadingAndDisablesButtons = false","            viewDisplaysTotalCount = remoteCounter.count","        }","    }","    ","    private func postNewValueToNetwork(newValue: Int) {","        effectsState.enqueue(","            Network.Effect<DTO>(request: try Network.buildURLRequestPosting(dto: DTO(count: newValue)))","                .map(When.networkPostCompleted)","        )","    }","}"],"type":"file","fileType":"swift","highlights":[{"line":6},{"line":48},{"line":50},{"line":51}],"syntax":"swift"}}}